{
    "name": "quickpay/laravel",
    "description": "Laravel integration package for the Quickpay.ge payment gateway",
    "type": "library",
    "license": "MIT",
    "keywords": ["quickpay", "payment", "georgia", "laravel", "sdk"],
    "homepage": "https://github.com/QuickPayGe/laravel-package",
    "support": {
        "source": "https://github.com/QuickPayGe/laravel-package",
        "issues": "https://github.com/QuickPayGe/laravel-package/issues"
    },
    "require": {
        "php": "^8.2",
        "quickpay/php-sdk": "^1.0",
        "laravel/framework": "^11.0||^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^9.0||^10.0"
    },
    "autoload": {
        "psr-4": {
            "Quickpay\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Quickpay\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quickpay\\Laravel\\QuickpayServiceProvider"
            ],
            "aliases": {
                "Quickpay": "Quickpay\\Laravel\\Facades\\Quickpay"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "version": "1.0.0"
}
